<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Student Record</title>
  <link rel="stylesheet" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            headline: ['"Noto Serif"'],
            body: ['"Manrope"'],
          },
          borderRadius: { DEFAULT: "0px", lg: "0px", xl: "0px", full: "9999px" },
        },
      },
    }
  </script>
  <style>
    @page {
      size: A4;
      margin: 0;
    }

    @media print {
      body {
        background: white !important;
        padding: 0 !important;
      }

      .page {
        box-shadow: none !important;
      }
    }

    body {
      margin: 0;
      padding: 0;
    }

    .a4 {
      width: 210mm;
      height: 297mm;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .page-border {
      width: 192mm;
      height: 279mm;
      border: 2px solid #111;
      padding: 3px;
      display: flex;
      flex-direction: column;
    }

    .page-inner {
      flex: 1;
      border: 1px solid #aaa;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      background: #fcf9f8;
      font-size: 11px;
    }
  </style>
  <%- include('partials/head') %>
</head>

<body onload="window.print()" class="font-body text-[#1c1b1b]">

  <div class="a4">
    <div class="page-border">
      <div class="page-inner">

        <div class="flex items-center justify-between px-7 py-3.5 border-b border-[#c6c6c6]/50">
          <div>
            <p class="font-body text-[8px] font-bold tracking-[0.22em] uppercase text-[#474747]">Official Academic

            </p>
            <h1 class="font-headline text-[21px] font-black tracking-tight leading-none text-[#111] mt-0.5">Student
              Record</h1>
          </div>
          <div class="text-right">
            <p class="font-headline text-[14px] font-black tracking-tighter text-[#111]">THIRD EYE COMPUTER EDUCATION
            </p>
            <p class="font-body text-[10px] tracking-[0.12em] uppercase text-[#474747] mt-0.5 font-bold">Kathiatoli
              &amp; Nagaon
            </p>
            <div class="mt-1.5 text-[#555] leading-tight">
              <p class="font-body text-[8px] font-bold uppercase tracking-wider">ISO 9001:2015 Certified Institution</p>
              <p class="font-body text-[8px] uppercase">Registered Under the Companies Act 1956,</p>
              <p class="font-body text-[8px] uppercase">Ministry of Corporate Affairs, Govt. of India</p>
              <p class="font-body text-[10px] uppercase font-bold">Registration No: U72400AS1998PTC005595</p>
            </div>
          </div>
        </div>

        <div class="px-7 py-4 border-b border-[#c6c6c6]/30">
          <div class="inline-block px-2.5 py-0.5 mb-1.5 border-b border-[#111]">
            <span class="font-body text-[8px] font-bold tracking-[0.2em] uppercase text-[#111]">Student Name</span>
          </div>
          <div class="flex items-end justify-between">
            <h2 class="font-headline text-[26px] font-black tracking-tighter leading-none uppercase text-[#111]">
              <%= student.name %>
            </h2>
          </div>
        </div>

        <div class="flex-1 px-7 py-4 flex flex-col gap-4">

          <div>
            <div class="flex items-end justify-between border-b border-[#c6c6c6]/40 pb-1 mb-3">
              <h3 class="font-headline text-[13px] font-bold tracking-tight">Personal Profile</h3>
              <span class="font-body text-[7.5px] uppercase tracking-widest text-[#474747]">Section 01</span>
            </div>
            <div class="grid grid-cols-3 gap-x-6 gap-y-3">
              <div>
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Father's
                  Name</label>
                <div class="font-body text-[10.5px] uppercase font-semibold border-b border-[#c6c6c6]/50 pb-1">
                  <%= student.fatherName %>
                </div>
              </div>
              <div>
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Mother's
                  Name</label>
                <div class="font-body text-[10.5px] uppercase font-semibold border-b border-[#c6c6c6]/50 pb-1">
                  <%= student.motherName %>
                </div>
              </div>
              <div>
                <label class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Date
                  of Birth</label>
                <div class="font-body text-[10.5px] font-semibold border-b border-[#c6c6c6]/50 pb-1">
                  <%= student.dateOfBirth ? new Date(student.dateOfBirth).toLocaleDateString('en-GB') : student.dob %>
                </div>
              </div>
              <div>
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Gender</label>
                <div class="font-body text-[10.5px] font-semibold border-b border-[#c6c6c6]/50 pb-1">
                  <%= student.gender %>
                </div>
              </div>
              <div>
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Phone
                  Number</label>
                <div class="font-body text-[10.5px] font-semibold border-b border-[#c6c6c6]/50 pb-1">
                  <%= student.phone %>
                </div>
              </div>
              <div>
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Email
                  Address</label>
                <div class="font-body text-[10.5px] font-semibold border-b border-[#c6c6c6]/50 pb-1 break-all">
                  <%= student.email %>
                </div>
              </div>
              <div>
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Qualification</label>
                <div class="font-body text-[10.5px] font-semibold border-b border-[#c6c6c6]/50 pb-1">
                  <%= student.qualification || 'N/A' %>
                </div>
              </div>
              <div>
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Enrollment
                  Type</label>
                <div class="font-body text-[10.5px] font-semibold border-b border-[#c6c6c6]/50 pb-1 capitalize">
                  <%= student.enrollmentType || 'offline' %>
                </div>
              </div>
            </div>
            <div class="mt-3">
              <label
                class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1">Residential
                Address</label>
              <div class="font-body text-[10.5px] font-semibold border-b border-[#c6c6c6]/50 pb-1">
                <%= student.address %>
              </div>
            </div>
          </div>

          <div class="px-5 border py-3.5">
            <div class="flex items-end justify-between mb-3">
              <h3 class="font-headline text-[13px] font-bold tracking-tight">Academic Enrollment</h3>
              <span class="font-body text-[7.5px] uppercase tracking-widest text-[#474747]">Section 02</span>
            </div>
            <div class="flex items-end gap-10">
              <div class="flex-1">
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1.5">Enrolled
                  Program</label>
                <p class="font-headline text-[17px] font-bold tracking-tight text-[#111]">
                  <%= student.course %>
                </p>
              </div>
              <div class="shrink-0">
                <label
                  class="block font-body text-[7px] uppercase tracking-[0.15em] text-[#474747] font-bold mb-1.5 ">Receipt
                  Number</label>
                <p class="font-body w-80 font-bold text-[12px] tracking-tight break-all">#<%= student.receiptNo %>
                </p>
              </div>
            </div>
          </div>

          <div>
            <div class="flex items-end justify-between border-b border-[#c6c6c6]/40 pb-1 mb-3">
              <h3 class="font-headline text-[13px] font-bold tracking-tight">Financial Summary</h3>
              <span class="font-body text-[7.5px] uppercase tracking-widest text-[#474747]">Section 03</span>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="border border-[#c6c6c6]/50 p-3 flex flex-col justify-between">
                <span class="font-body text-[7px] uppercase tracking-widest font-bold text-[#474747]">Total Fees</span>
                <span class="font-headline text-[19px] font-black text-[#111] mt-1.5">₹<%= student.totalFees %></span>
              </div>
              <div class="border border-[#c6c6c6]/50 p-3 flex flex-col justify-between">
                <span class="font-body text-[7px] uppercase tracking-widest font-bold text-[#474747]">Total
                  Collected</span>
                <span class="font-headline text-[19px] font-black text-[#111] mt-1.5">₹<%= student.collectedFees %>
                </span>
              </div>
              <div class="border border-[#c6c6c6]/50 p-3 flex flex-col justify-between">
                <span class="font-body text-[7px] uppercase tracking-[0.2em] font-black text-[#474747]">Remaining
                  Balance</span>
                <span class="font-headline text-[19px] font-black text-[#1c1b1b] mt-1.5">₹<%= student.remainingFees %>
                </span>
              </div>
            </div>
          </div>

          <div class=" flex items-end justify-between mt-32">
            <div>

            </div>
            <div class="grid ">
              <div class="flex flex-col items-center">
                <div class="w-32 h-9 mb-1.5 border-b border-[#111]/20"></div>
                <span class="font-body text-[7.5px] uppercase tracking-widest font-bold">
                  <p>Students Signature</p>
                </span>
              </div>
              <div class="w-32 h-9 mb-1.5 mt-4 border-b border-[#111]/20"></div>
              <span class="font-body text-[7.5px] ml-3 uppercase tracking-widest font-bold">
                <p>Authorized Signature</p>
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="px-7 py-2.5 flex items-center justify-between">
        <span class="font-headline font-bold italic text-[10px] text-[#111]">Third Eye Computer Education © <%= new
            Date().getFullYear() %> </span>
        <span class="font-body text-[7.5px] text-[#1c1b1b]/40 tracking-wide">

          <div>
            <p class="font-body text-[7.5px] uppercase tracking-widest text-[#111]">Admission Date</p>
            <p class="font-body text-[12px] font-bold border-b-black text-[#111] mb-2">
              _____/______/__________
            </p>
          </div>

          <div>
            <p class="font-body text-[7.5px] uppercase tracking-widest text-[#111]">Class Start Date</p>
            <p class="font-body text-[12px] font-bold border-b-black text-[#111] mt-0.5">
              _____/______/__________
            </p>
          </div>
        </span>
      </div>

    </div>
  </div>
  </div>

  <%- include('partials/footer') %>
</body>

</html>